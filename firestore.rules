rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone can submit the contact form (creates a new lead), but only
    // the logged-in admin can read, update, or delete leads.
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Everything else (portfolio, services, pricing, testimonials, faq,
    // team, media, settings/*) is publicly readable — the live website
    // needs to load it without logging in — but only the authenticated
    // admin can create, edit, delete, or reorder it.
    match /{collection}/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
